generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// 1. AUTH & USER MANAGEMENT
// ============================================================

model User {
  id                BigInt    @id @default(autoincrement())
  fullName          String    @map("full_name") @db.VarChar(150)
  email             String    @unique @db.VarChar(255)
  phone             String?   @db.VarChar(20)
  passwordHash      String?   @map("password_hash") @db.VarChar(255)
  role              String    @default("user") @db.VarChar(20)
  status            String    @default("active") @db.VarChar(20)
  avatarUrl         String?   @map("avatar_url")
  googleId          String?   @unique @map("google_id") @db.VarChar(100)
  emailVerifiedAt   DateTime? @map("email_verified_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  refreshTokens   RefreshToken[]
  passwordResets  PasswordReset[]
  hotels          Hotel[]
  vouchers        Voucher[]
  bookings        Booking[]
  reviews         Review[]
  wishlists       Wishlist[]
  notifications   Notification[]
  voucherUsages   VoucherUsage[]

  @@index([role])
  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id         BigInt    @id @default(autoincrement())
  userId     BigInt    @map("user_id")
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

model PasswordReset {
  id         BigInt   @id @default(autoincrement())
  userId     BigInt   @map("user_id")
  tokenHash  String   @unique @map("token_hash") @db.VarChar(255)
  used       Boolean  @default(false)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("password_resets")
}

// ============================================================
// 2. HOTELS
// ============================================================

model Hotel {
  id           BigInt    @id @default(autoincrement())
  partnerId    BigInt    @map("partner_id")
  name         String    @db.VarChar(200)
  slug         String    @unique @db.VarChar(220)
  description  String?
  address      String
  city         String    @db.VarChar(100)
  district     String?   @db.VarChar(100)
  country      String    @default("Vietnam") @db.VarChar(100)
  latitude     Decimal?  @db.Decimal(10, 7)
  longitude    Decimal?  @db.Decimal(10, 7)
  starRating   Int?      @map("star_rating") @db.SmallInt
  status       String    @default("pending") @db.VarChar(20)
  avgRating    Decimal   @default(0) @map("avg_rating") @db.Decimal(3, 2)
  reviewCount  Int       @default(0) @map("review_count")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  partner    User           @relation(fields: [partnerId], references: [id])
  images     HotelImage[]
  amenities  HotelAmenity[]
  rooms      Room[]
  reviews    Review[]
  wishlists  Wishlist[]

  @@index([partnerId])
  @@index([city])
  @@index([status])
  @@index([latitude, longitude])
  @@index([avgRating])
  @@index([deletedAt])
  @@map("hotels")
}

model HotelImage {
  id         BigInt  @id @default(autoincrement())
  hotelId    BigInt  @map("hotel_id")
  url        String
  altText    String? @map("alt_text") @db.VarChar(200)
  isCover    Boolean @default(false) @map("is_cover")
  sortOrder  Int     @default(0) @map("sort_order")

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@map("hotel_images")
}

model HotelAmenity {
  id       BigInt  @id @default(autoincrement())
  hotelId  BigInt  @map("hotel_id")
  name     String  @db.VarChar(100)
  icon     String? @db.VarChar(100)

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@map("hotel_amenities")
}

// ============================================================
// 3. ROOMS
// ============================================================

model Room {
  id           BigInt    @id @default(autoincrement())
  hotelId      BigInt    @map("hotel_id")
  name         String    @db.VarChar(150)
  description  String?
  maxGuests    Int       @default(2) @map("max_guests") @db.SmallInt
  bedType      String?   @map("bed_type") @db.VarChar(80)
  areaSqm      Decimal?  @map("area_sqm") @db.Decimal(6, 2)
  basePrice    Decimal   @map("base_price") @db.Decimal(12, 2)
  totalUnits   Int       @default(1) @map("total_units") @db.SmallInt
  status       String    @default("active") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  hotel         Hotel              @relation(fields: [hotelId], references: [id])
  images        RoomImage[]
  availability  RoomAvailability[]
  bookingRooms  BookingRoom[]

  @@index([hotelId])
  @@index([deletedAt])
  @@map("rooms")
}

model RoomImage {
  id         BigInt @id @default(autoincrement())
  roomId     BigInt @map("room_id")
  url        String
  sortOrder  Int    @default(0) @map("sort_order")

  room Room @relation(fields: [roomId], references: [id])

  @@map("room_images")
}

model RoomAvailability {
  id              BigInt   @id @default(autoincrement())
  roomId          BigInt   @map("room_id")
  date            DateTime @db.Date
  availableUnits  Int      @map("available_units") @db.SmallInt
  priceOverride   Decimal? @map("price_override") @db.Decimal(12, 2)

  room Room @relation(fields: [roomId], references: [id])

  @@unique([roomId, date])
  @@map("room_availability")
}

// ============================================================
// 4. VOUCHERS
// ============================================================

model Voucher {
  id              BigInt    @id @default(autoincrement())
  createdBy       BigInt    @map("created_by")
  code            String    @unique @db.VarChar(50)
  description     String?
  discountType    String    @map("discount_type") @db.VarChar(10)
  discountValue   Decimal   @map("discount_value") @db.Decimal(10, 2)
  maxDiscount     Decimal?  @map("max_discount") @db.Decimal(10, 2)
  minOrderValue   Decimal   @default(0) @map("min_order_value") @db.Decimal(10, 2)
  usageLimit      Int?      @map("usage_limit")
  usageCount      Int       @default(0) @map("usage_count")
  perUserLimit    Int       @default(1) @map("per_user_limit") @db.SmallInt
  validFrom       DateTime  @map("valid_from") @db.Date
  validUntil      DateTime  @map("valid_until") @db.Date
  status          String    @default("active") @db.VarChar(20)
  createdAt       DateTime  @default(now()) @map("created_at")
  deletedAt       DateTime? @map("deleted_at")

  creator       User           @relation(fields: [createdBy], references: [id])
  usages        VoucherUsage[]
  bookings      Booking[]

  @@map("vouchers")
}

model VoucherUsage {
  id               BigInt   @id @default(autoincrement())
  voucherId        BigInt   @map("voucher_id")
  userId           BigInt   @map("user_id")
  bookingId        BigInt   @map("booking_id")
  discountApplied  Decimal  @map("discount_applied") @db.Decimal(10, 2)
  usedAt           DateTime @default(now()) @map("used_at")

  voucher  Voucher @relation(fields: [voucherId], references: [id])
  user     User    @relation(fields: [userId], references: [id])
  booking  Booking @relation(fields: [bookingId], references: [id])

  @@map("voucher_usages")
}

// ============================================================
// 5. BOOKINGS
// ============================================================

model Booking {
  id               BigInt    @id @default(autoincrement())
  userId           BigInt    @map("user_id")
  voucherId        BigInt?   @map("voucher_id")
  bookingCode      String    @unique @map("booking_code") @db.VarChar(20)
  checkIn          DateTime  @map("check_in") @db.Date
  checkOut         DateTime  @map("check_out") @db.Date
  guestCount       Int       @map("guest_count") @db.SmallInt
  subtotal         Decimal   @db.Decimal(12, 2)
  discountAmount   Decimal   @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount      Decimal   @map("total_amount") @db.Decimal(12, 2)
  status           String    @default("pending") @db.VarChar(20)
  specialRequests  String?   @map("special_requests")
  cancelledAt      DateTime? @map("cancelled_at")
  cancelReason     String?   @map("cancel_reason")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id])
  voucher       Voucher?       @relation(fields: [voucherId], references: [id])
  bookingRooms  BookingRoom[]
  payment       Payment?
  review        Review?
  voucherUsage  VoucherUsage[]

  @@index([userId])
  @@index([status])
  @@index([checkIn, checkOut])
  @@index([bookingCode])
  @@map("bookings")
}

model BookingRoom {
  id             BigInt  @id @default(autoincrement())
  bookingId      BigInt  @map("booking_id")
  roomId         BigInt  @map("room_id")
  units          Int     @default(1) @db.SmallInt
  pricePerNight  Decimal @map("price_per_night") @db.Decimal(12, 2)
  nights         Int     @db.SmallInt
  subtotal       Decimal @db.Decimal(12, 2)

  booking Booking @relation(fields: [bookingId], references: [id])
  room    Room    @relation(fields: [roomId], references: [id])

  @@map("booking_rooms")
}

// ============================================================
// 6. PAYMENTS
// ============================================================

model Payment {
  id               BigInt    @id @default(autoincrement())
  bookingId        BigInt    @unique @map("booking_id")
  amount           Decimal   @db.Decimal(12, 2)
  method           String    @db.VarChar(30)
  status           String    @default("pending") @db.VarChar(20)
  transactionId    String?   @map("transaction_id") @db.VarChar(200)
  gatewayResponse  Json?     @map("gateway_response")
  refundAmount     Decimal?  @map("refund_amount") @db.Decimal(12, 2)
  refundedAt       DateTime? @map("refunded_at")
  paidAt           DateTime? @map("paid_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([status])
  @@map("payments")
}

// ============================================================
// 7. REVIEWS
// ============================================================

model Review {
  id            BigInt    @id @default(autoincrement())
  userId        BigInt    @map("user_id")
  hotelId       BigInt    @map("hotel_id")
  bookingId     BigInt    @unique @map("booking_id")
  rating        Int       @db.SmallInt
  cleanliness   Int?      @db.SmallInt
  service       Int?      @db.SmallInt
  location      Int?      @db.SmallInt
  value         Int?      @db.SmallInt
  content       String?
  isHidden      Boolean   @default(false) @map("is_hidden")
  partnerReply  String?   @map("partner_reply")
  repliedAt     DateTime? @map("replied_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  hotel   Hotel   @relation(fields: [hotelId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([hotelId])
  @@index([userId])
  @@map("reviews")
}

// ============================================================
// 8. WISHLISTS
// ============================================================

model Wishlist {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  hotelId   BigInt   @map("hotel_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id])
  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@unique([userId, hotelId])
  @@map("wishlists")
}

// ============================================================
// 9. NOTIFICATIONS
// ============================================================

model Notification {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt   @map("user_id")
  title     String   @db.VarChar(200)
  body      String
  type      String   @db.VarChar(50)
  data      Json?
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}
